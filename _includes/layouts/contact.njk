{% extends "layouts/base.njk" %}

{% block bodyClasses %}page-contact{% endblock %}

{% block main %}

{% include "partials/hero-setheight.njk" %}

<div class="container pt-8 pb-8 pt-md-12 pb-md-12">
  <div class="row">

    {# Formulaire de contact (Web3Forms) #}
    <div class="col-12 col-md-6 mb-6 mb-md-0">
      <h2>Envoyez-nous un message</h2>
      <form action="https://api.web3forms.com/submit" method="POST" class="mt-3">
        <input type="hidden" name="access_key" value="415e9aa8-a1f4-4f49-bfc8-36f14f5495a1">
        <input type="hidden" name="subject" value="Nouveau message - Aksel San Tattoo">
        <input type="hidden" name="redirect" value="false">
        <input type="checkbox" name="botcheck" class="visually-hidden" tabindex="-1" autocomplete="off">
        <div class="mb-3">
          <label for="nom" class="form-label">Nom</label>
          <input type="text" class="form-control" id="nom" name="nom" required>
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input type="email" class="form-control" id="email" name="email" required>
        </div>
        <div class="mb-3">
          <label for="objet" class="form-label">Objet</label>
          <input type="text" class="form-control" id="objet" name="objet">
        </div>
        <div class="mb-3">
          <label for="message" class="form-label">Message</label>
          <textarea class="form-control" id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Envoyer</button>
      </form>
    </div>

    {# Coordonnées #}
    <div class="col-12 col-md-5 offset-md-1">
      <h2>Coordonnées</h2>
      <div class="mt-3">
        <p>
          <strong>{{ contact.businessName }}</strong><br>
          {{ contact.studio }}<br>
          <span style="white-space:pre-wrap;">{{ contact.address }}</span>
        </p>
        <p>
          <strong>Téléphone :</strong>
          <a href="tel:{{ contact.phone | replace(' ', '') }}">{{ contact.phone }}</a>
        </p>
        <p>
          <strong>Email :</strong>
          <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>
        </p>
        <p>
          <strong>Instagram :</strong>
          <a href="https://www.instagram.com/{{ contact.social_handle }}/" target="_blank" rel="noopener noreferrer">@{{ contact.social_handle }}</a>
        </p>
        <p>
          <strong>Facebook :</strong>
          <a href="https://www.facebook.com/aksel.san.tattoo/" target="_blank" rel="noopener noreferrer">aksel.san.tattoo</a>
        </p>
      </div>

      {# Plan d'accès OpenStreetMap #}
      <div class="mt-4">
        <h3>Plan d'accès</h3>
        <div style="border-radius:4px;overflow:hidden;margin-top:1rem;">
          <iframe
            title="Plan d'accès Asphalt Jungle, Ostwald"
            src="https://www.openstreetmap.org/export/embed.html?bbox=7.694%2C48.540%2C7.712%2C48.550&layer=mapnik&marker=48.5451%2C7.7031"
            width="100%"
            height="300"
            style="border:0;display:block;"
            loading="lazy"
            allowfullscreen
          ></iframe>
          <small><a href="https://www.openstreetmap.org/?mlat=48.5451&mlon=7.7031#map=16/48.5451/7.7031" target="_blank" rel="noopener noreferrer">Voir en plein écran</a></small>
        </div>
      </div>
    </div>

  </div>
</div>

{% endblock %}
