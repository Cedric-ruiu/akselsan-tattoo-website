{% extends "layouts/base.njk" %}

{% block bodyClasses %}page-portfolio{% endblock %}

{% block main %}

{% include "partials/hero-setheight.njk" %}

{% if content %}
<div class="container pt-4 pt-md-6">
  <div class="row">
    <div class="col-12">
      <div class="page-intro">
        {{ content | safe }}
      </div>
    </div>
  </div>
</div>
{% endif %}

<div class="container pb-6 pt-4 pt-md-6 pb-md-10">
  <div class="row g-2">
    {% for img in portfolio_images.images %}
    <div class="col-12 col-md-4">
      <img
        src="{{ img.src }}"
        alt="{{ img.alt }}"
        width="600"
        height="600"
        class="img-fluid w-100"
        style="aspect-ratio:1/1;object-fit:cover;"
        loading="lazy"
      >
    </div>
    {% endfor %}
  </div>
</div>

{% endblock %}
